{
  "compilerOptions": {
    "module": "Node16",
    "target": "ES2022",
    "moduleResolution": "Node16",
    "outDir": "dist",
    "lib": ["ES2022"],
    "sourceMap": true,
    "rootDir": "src",
    "strict": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts"],
  // src/e2e/vscode is the headless VS Code integration harness (mocha +
  // @vscode/test-electron). It is compiled only by tsconfig.e2e.json so its
  // mocha globals never leak into the extension build.
  "exclude": ["node_modules", "dist", "src/e2e/vscode"]
}
